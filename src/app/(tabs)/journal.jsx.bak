import { useState, useCallback, useEffect, useMemo } from 'react';
import {
  View,
  Text,
  Pressable,
  Dimensions,
  ScrollView,
  TextInput,
  KeyboardAvoidingView,
  Platform,
  Modal,
  TouchableWithoutFeedback,
  Keyboard,
  StyleSheet,
  ActivityIndicator,
} from 'react-native';
import { StatusBar } from 'expo-status-bar';
import { useSafeAreaInsets } from 'react-native-safe-area-context';
import { LinearGradient } from 'expo-linear-gradient';
import { BlurView } from 'expo-blur';
import { Sparkles, Plus, Calendar, Activity, Briefcase, Heart, MessageSquare } from 'lucide-react-native';
import AsyncStorage from '@react-native-async-storage/async-storage';

const { width, height } = Dimensions.get('window');

const REVIEWS_KEY = 'alchemy_reviews';
const DREAM_KEY = 'alchemy_user_dream';

const AI_TITLES = [
  "The Genesis of Focus",
  "A Crucible of Routine",
  "Somatic Realignment",
  "Echoes of Ambition",
  "The Architecture of Habit",
  "Restless Restoration",
  "Vibrations of Abundance",
  "The Discipline Paradigm",
  "Resonance in Relationships",
  "The Velocity of Purpose",
  "Unlocking Vitality",
  "Threshold of Alignment",
];

// Helper to format date
const formatDate = (dateStr) => {
  const options = { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' };
  return new Date(dateStr).toLocaleDateString('en-US', options);
};

export default function JournalScreen() {
  const insets = useSafeAreaInsets();

  // State
  const [reviews, setReviews] = useState([]);
  const [dream, setDream] = useState('');
  const [loading, setLoading] = useState(true);

  // Modal visibilities
  const [dreamModalVisible, setDreamModalVisible] = useState(false);
  const [reviewModalVisible, setReviewModalVisible] = useState(false);

  // Form states
  const [tempDream, setTempDream] = useState('');
  const [answers, setAnswers] = useState({
    habits: '',
    health: '',
    financial: '',
    relationships: '',
  });

  // Load reviews and dream on mount
  useEffect(() => {
    const loadStore = async () => {
      try {
        const savedDream = await AsyncStorage.getItem(DREAM_KEY);
        if (savedDream) {
          setDream(savedDream);
          setTempDream(savedDream);
        }

        const savedReviews = await AsyncStorage.getItem(REVIEWS_KEY);
        if (savedReviews) {
          setReviews(JSON.parse(savedReviews));
        }
      } catch (e) {
        console.error("Load storage error in journal:", e);
      } finally {
        setLoading(false);
      }
    };
    loadStore();
  }, []);

  // Compute calculated metrics
  const metrics = useMemo(() => {
    const base = { health: 50, career: 50, relationships: 50, mindset: 50 };
    if (!reviews || reviews.length === 0) return base;
    reviews.forEach(rev => {
      if (rev.metricsChanged) {
        base.health = Math.max(0, Math.min(100, base.health + (rev.metricsChanged.health || 0)));
        base.career = Math.max(0, Math.min(100, base.career + (rev.metricsChanged.career || 0)));
        base.relationships = Math.max(0, Math.min(100, base.relationships + (rev.metricsChanged.relationships || 0)));
        base.mindset = Math.max(0, Math.min(100, base.mindset + (rev.metricsChanged.mindset || 0)));
      }
    });
    return base;
  }, [reviews]);

  // Save dream
  const saveDream = async () => {
    try {
      await AsyncStorage.setItem(DREAM_KEY, tempDream);
      setDream(tempDream);
      setDreamModalVisible(false);
    } catch (e) {
      console.error(e);
    }
  };

  // Analyze metrics changes based on weekly reviews content to create AI feel
  const analyzeWeeklyInput = (formAnswers) => {
    const fullText = Object.values(formAnswers).join(' ').toLowerCase();
    const changes = { health: 0, career: 0, relationships: 0, mindset: 0 };

    // 1. Health
    if (fullText.includes('sleep') || fullText.includes('gym') || fullText.includes('run') || fullText.includes('workout') || fullText.includes('water')) {
      changes.health = Math.floor(Math.random() * 3) + 1; // +1% to +3%
    } else {
      changes.health = Math.random() > 0.5 ? 0 : -1;
    }

    // 2. Career & Money
    if (fullText.includes('work') || fullText.includes('study') || fullText.includes('code') || fullText.includes('save') || fullText.includes('budget')) {
      changes.career = Math.floor(Math.random() * 3) + 1;
    } else {
      changes.career = Math.random() > 0.5 ? 0 : -1;
    }

    // 3. Relationships
    if (fullText.includes('friend') || fullText.includes('family') || fullText.includes('partner') || fullText.includes('date') || fullText.includes('talk')) {
      changes.relationships = Math.floor(Math.random() * 3) + 1;
    } else {
      changes.relationships = Math.random() > 0.5 ? 0 : -1;
    }

    // 4. Mindset
    const positiveWords = ['good', 'great', 'happy', 'focus', 'discipline', 'positive', 'productive', 'proud'];
    let mindsetInc = 1;
    positiveWords.forEach(word => {
      if (fullText.includes(word)) mindsetInc += 1;
    });
    changes.mindset = mindsetInc;

    return changes;
  };

  // Submit new review
  const submitReview = async () => {
    if (!answers.habits || !answers.health || !answers.financial || !answers.relationships) {
      alert("Please fill in all review sections.");
      return;
    }

    const metricsChanged = analyzeWeeklyInput(answers);
    const newTitle = AI_TITLES[Math.floor(Math.random() * AI_TITLES.length)];
    const newEntry = {
      id: Date.now().toString(),
      date: new Date().toISOString().split('T')[0],
      title: newTitle,
      answers: { ...answers },
      metricsChanged,
    };

    const updatedReviews = [...reviews, newEntry]; // Chronologically stacking (appended to end)
    setReviews(updatedReviews);
    await AsyncStorage.setItem(REVIEWS_KEY, JSON.stringify(updatedReviews));

    // Reset Form
    setAnswers({ habits: '', health: '', financial: '', relationships: '' });
    setReviewModalVisible(false);
  };

  return (
    <View style={{ flex: 1, backgroundColor: '#020206' }}>
      <StatusBar style="light" />

      {/* Deep Space Navy-Black background */}
      <LinearGradient
        colors={['#020208', '#04091a', '#010103']}
        start={{ x: 0, y: 0 }}
        end={{ x: 0, y: 1 }}
        style={StyleSheet.absoluteFillObject}
      />

      {loading ? (
        <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
          <ActivityIndicator size="large" color="#FFFFFF" />
        </View>
      ) : (
        <ScrollView
          style={{ flex: 1 }}
          contentContainerStyle={{
            paddingTop: insets.top + 16,
            paddingHorizontal: 20,
            paddingBottom: 110, // Avoid overlapping floating navigation
          }}
          showsVerticalScrollIndicator={false}
        >
          {/* HEADER TITLE */}
          <View style={{ alignItems: 'center', marginBottom: 24 }}>
            <Text style={{ fontSize: 18, fontWeight: '700', color: '#ffffff', letterSpacing: 1, textTransform: 'uppercase' }}>
              Review Timeline
            </Text>
            <Text style={{ fontSize: 11, color: 'rgba(255, 255, 255, 0.4)', marginTop: 4 }}>
              Chronological Path of your Future Self
            </Text>
          </View>

          {/* DYNAMIC FUTURE METRICS GAUGES */}
          <BlurView intensity={30} tint="dark" style={styles.metricsContainer}>
            <Text style={styles.sectionHeader}>Future Calibrations</Text>
            <View style={{ gap: 14 }}>
              {/* Health Future */}
              <View>
                <View style={styles.metricLabelRow}>
                  <View style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
                    <Activity size={13} color="#00FA9A" />
                    <Text style={styles.metricName}>Health Future</Text>
                  </View>
                  <Text style={styles.metricVal}>{metrics.health}%</Text>
                </View>
                <View style={styles.barBg}>
                  <View style={[styles.barFill, { width: `${metrics.health}%`, backgroundColor: '#00FA9A' }]} />
                </View>
              </View>

              {/* Career Future */}
              <View>
                <View style={styles.metricLabelRow}>
                  <View style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
                    <Briefcase size={13} color="#0A1BFF" />
                    <Text style={styles.metricName}>Career Future</Text>
                  </View>
                  <Text style={styles.metricVal}>{metrics.career}%</Text>
                </View>
                <View style={styles.barBg}>
                  <View style={[styles.barFill, { width: `${metrics.career}%`, backgroundColor: '#0A1BFF' }]} />
                </View>
              </View>

              {/* Relationships */}
              <View>
                <View style={styles.metricLabelRow}>
                  <View style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
                    <Heart size={13} color="#FF6347" />
                    <Text style={styles.metricName}>Relationships</Text>
                  </View>
                  <Text style={styles.metricVal}>{metrics.relationships}%</Text>
                </View>
                <View style={styles.barBg}>
                  <View style={[styles.barFill, { width: `${metrics.relationships}%`, backgroundColor: '#FF6347' }]} />
                </View>
              </View>

              {/* Mindset */}
              <View>
                <View style={styles.metricLabelRow}>
                  <View style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
                    <Sparkles size={13} color="#FFD700" />
                    <Text style={styles.metricName}>Mindset</Text>
                  </View>
                  <Text style={styles.metricVal}>{metrics.mindset}%</Text>
                </View>
                <View style={styles.barBg}>
                  <View style={[styles.barFill, { width: `${metrics.mindset}%`, backgroundColor: '#FFD700' }]} />
                </View>
              </View>
            </View>
          </BlurView>

          {/* ACTION BUTTONS ROW */}
          <View style={{ flexDirection: 'row', gap: 14, marginBottom: 28 }}>
            <Pressable
              onPress={() => setDreamModalVisible(true)}
              style={({ pressed }) => [styles.actionButton, pressed && styles.pressedEffect]}
            >
              <BlurView intensity={20} tint="dark" style={styles.btnInner}>
                <Sparkles size={15} color="#FFD700" />
                <Text style={styles.btnText}>Dream Vision</Text>
              </BlurView>
            </Pressable>

            <Pressable
              onPress={() => setReviewModalVisible(true)}
              style={({ pressed }) => [styles.actionButton, pressed && styles.pressedEffect]}
            >
              <BlurView intensity={20} tint="dark" style={styles.btnInner}>
                <Plus size={16} color="#00FA9A" />
                <Text style={styles.btnText}>Weekly Log</Text>
              </BlurView>
            </Pressable>
          </View>

          {/* TIMELINE LIST STACKING (Oldest at the bottom, Newest at top / stacked chronologically) */}
          <View style={{ gap: 20 }}>
            {reviews.length === 0 ? (
              <View style={styles.emptyContainer}>
                <Text style={styles.emptyText}>Your chronological timeline is currently quiet.</Text>
                <Text style={styles.emptySubtext}>Submit a Weekly Log or describe your Dream Vision to begin calibrating the portal.</Text>
              </View>
            ) : (
              reviews.map((item, idx) => (
                <View key={item.id} style={styles.cardContainer}>
                  {/* Vertical Connection Line */}
                  {idx < reviews.length - 1 && <View style={styles.connectorLine} />}
                  
                  {/* Timeline dot icon indicator */}
                  <View style={styles.timelineDot}>
                    <Calendar size={12} color="#00FA9A" />
                  </View>

                  <BlurView intensity={15} tint="dark" style={styles.reviewCard}>
                    {/* Header: Title and Date */}
                    <View style={{ flexDirection: 'row', justifyContent: 'space-between', alignItems: 'flex-start', flexWrap: 'wrap', gap: 6 }}>
                      <Text style={styles.cardTitle}>{item.title}</Text>
                      <Text style={styles.cardDate}>{formatDate(item.date)}</Text>
                    </View>

                    {/* Short Answer summaries */}
                    <View style={styles.answersSummary}>
                      <Text style={styles.answerText} numberOfLines={2}>
                        <Text style={{ fontWeight: '600', color: 'rgba(255,255,255,0.7)' }}>Habits: </Text>
                        {item.answers.habits}
                      </Text>
                      <Text style={styles.answerText} numberOfLines={2}>
                        <Text style={{ fontWeight: '600', color: 'rgba(255,255,255,0.7)' }}>Health: </Text>
                        {item.answers.health}
                      </Text>
                      <Text style={styles.answerText} numberOfLines={2}>
                        <Text style={{ fontWeight: '600', color: 'rgba(255,255,255,0.7)' }}>Finances: </Text>
                        {item.answers.financial}
                      </Text>
                      <Text style={styles.answerText} numberOfLines={2}>
                        <Text style={{ fontWeight: '600', color: 'rgba(255,255,255,0.7)' }}>Connections: </Text>
                        {item.answers.relationships}
                      </Text>
                    </View>

                    {/* Metrics changed summary block */}
                    <View style={styles.impactContainer}>
                      <Text style={styles.impactTitle}>Calibrations Impact:</Text>
                      <View style={styles.impactRow}>
                        {Object.entries(item.metricsChanged || {}).map(([metric, change]) => {
                          const label = metric.charAt(0).toUpperCase() + metric.slice(1);
                          const sign = change > 0 ? `+${change}%` : change === 0 ? 'unchanged' : `${change}%`;
                          const textColor = change > 0 ? '#00FA9A' : change === 0 ? 'rgba(255,255,255,0.35)' : '#FF6347';
                          return (
                            <Text key={metric} style={[styles.impactLabel, { color: textColor }]}>
                              {label} {sign}
                            </Text>
                          );
                        })}
                      </View>
                    </View>
                  </BlurView>
                </View>
              ))
            )}
          </View>
        </ScrollView>
      )}

      {/* DREAM VISION MODAL */}
      <Modal visible={dreamModalVisible} transparent animationType="fade" statusBarTranslucent>
        <TouchableWithoutFeedback onPress={() => setDreamModalVisible(false)}>
          <View style={styles.modalBg}>
            <TouchableWithoutFeedback>
              <KeyboardAvoidingView behavior={Platform.OS === 'ios' ? 'padding' : 'height'} style={styles.modalWrapper}>
                <BlurView intensity={85} tint="dark" style={styles.modalContent}>
                  <View style={styles.modalHeader}>
                    <Sparkles size={16} color="#FFD700" />
                    <Text style={styles.modalTitle}>Dream Vision</Text>
                  </View>
                  <Text style={styles.modalSubtitle}>
                    Describe your ideal dream future. The mirror portal reads this to shape future projections.
                  </Text>
                  
                  <TextInput
                    style={styles.textArea}
                    multiline
                    numberOfLines={6}
                    value={tempDream}
                    onChangeText={setTempDream}
                    placeholder="Describe your ideal self, career accomplishments, physical status, mental mastery, and family vision..."
                    placeholderTextColor="rgba(255,255,255,0.25)"
                  />

                  <View style={{ flexDirection: 'row', gap: 12, marginTop: 18 }}>
                    <Pressable onPress={() => setDreamModalVisible(false)} style={styles.cancelBtn}>
                      <Text style={{ color: '#fff', fontSize: 13, fontWeight: '600' }}>Cancel</Text>
                    </Pressable>
                    <Pressable onPress={saveDream} style={styles.saveBtn}>
                      <Text style={{ color: '#000', fontSize: 13, fontWeight: '700' }}>Engrave Dream</Text>
                    </Pressable>
                  </View>
                </BlurView>
              </KeyboardAvoidingView>
            </TouchableWithoutFeedback>
          </View>
        </TouchableWithoutFeedback>
      </Modal>

      {/* WEEKLY LOG MODAL */}
      <Modal visible={reviewModalVisible} transparent animationType="fade" statusBarTranslucent>
        <TouchableWithoutFeedback onPress={() => setReviewModalVisible(false)}>
          <View style={styles.modalBg}>
            <TouchableWithoutFeedback>
              <KeyboardAvoidingView behavior={Platform.OS === 'ios' ? 'padding' : 'height'} style={styles.modalWrapper}>
                <BlurView intensity={85} tint="dark" style={styles.modalContent}>
                  <View style={styles.modalHeader}>
                    <Plus size={16} color="#00FA9A" />
                    <Text style={styles.modalTitle}>Weekly Log</Text>
                  </View>
                  <Text style={styles.modalSubtitle}>
                    Calibrate metrics by logging habits, health, finances, and connections.
                  </Text>

                  <ScrollView style={{ maxHeight: height * 0.45 }} showsVerticalScrollIndicator={false}>
                    <View style={{ gap: 14, paddingBottom: 10 }}>
                      <View>
                        <Text style={styles.fieldLabel}>Habits & Routine</Text>
                        <TextInput
                          style={styles.fieldInput}
                          placeholder="What routines did you uphold?"
                          placeholderTextColor="rgba(255,255,255,0.25)"
                          value={answers.habits}
                          onChangeText={(t) => setAnswers(prev => ({ ...prev, habits: t }))}
                        />
                      </View>

                      <View>
                        <Text style={styles.fieldLabel}>Health & Vigor</Text>
                        <TextInput
                          style={styles.fieldInput}
                          placeholder="How was sleep, nutrition, and exercise?"
                          placeholderTextColor="rgba(255,255,255,0.25)"
                          value={answers.health}
                          onChangeText={(t) => setAnswers(prev => ({ ...prev, health: t }))}
                        />
                      </View>

                      <View>
                        <Text style={styles.fieldLabel}>Finance & Security</Text>
                        <TextInput
                          style={styles.fieldInput}
                          placeholder="What are your financial decisions?"
                          placeholderTextColor="rgba(255,255,255,0.25)"
                          value={answers.financial}
                          onChangeText={(t) => setAnswers(prev => ({ ...prev, financial: t }))}
                        />
                      </View>

                      <View>
                        <Text style={styles.fieldLabel}>Connections & Relations</Text>
                        <TextInput
                          style={styles.fieldInput}
                          placeholder="How are relations with friends/family?"
                          placeholderTextColor="rgba(255,255,255,0.25)"
                          value={answers.relationships}
                          onChangeText={(t) => setAnswers(prev => ({ ...prev, relationships: t }))}
                        />
                      </View>
                    </View>
                  </ScrollView>

                  <View style={{ flexDirection: 'row', gap: 12, marginTop: 18 }}>
                    <Pressable onPress={() => setReviewModalVisible(false)} style={styles.cancelBtn}>
                      <Text style={{ color: '#fff', fontSize: 13, fontWeight: '600' }}>Cancel</Text>
                    </Pressable>
                    <Pressable onPress={submitReview} style={styles.saveBtn}>
                      <Text style={{ color: '#000', fontSize: 13, fontWeight: '700' }}>Calibrate Log</Text>
                    </Pressable>
                  </View>
                </BlurView>
              </KeyboardAvoidingView>
            </TouchableWithoutFeedback>
          </View>
        </TouchableWithoutFeedback>
      </Modal>
    </View>
  );
}

const styles = StyleSheet.create({
  metricsContainer: {
    borderRadius: 20,
    padding: 18,
    borderWidth: 1,
    borderColor: 'rgba(255,255,255,0.06)',
    backgroundColor: 'rgba(10,10,25,0.2)',
    marginBottom: 20,
    overflow: 'hidden',
  },
  sectionHeader: {
    color: 'rgba(255,255,255,0.4)',
    fontSize: 10,
    fontWeight: '700',
    letterSpacing: 1.5,
    textTransform: 'uppercase',
    marginBottom: 16,
  },
  metricLabelRow: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'center',
    marginBottom: 4,
  },
