    borderWidth: 1,
    borderColor: 'rgba(0, 250, 154, 0.4)',
    alignItems: 'center',
    justifyContent: 'center',
    zIndex: 2,
    shadowColor: '#00FA9A',
    shadowOffset: { width: 0, height: 0 },
    shadowOpacity: 0.5,
    shadowRadius: 4,
  },
  reviewCard: {
    borderRadius: 18,
    padding: 16,
    borderWidth: 1,
    borderColor: 'rgba(255,255,255,0.05)',
    backgroundColor: 'rgba(255,255,255,0.01)',
    overflow: 'hidden',
  },
  cardTitle: {
    color: '#fff',
    fontSize: 14,
    fontWeight: '700',
    letterSpacing: 0.5,
  },
  cardDate: {
    color: 'rgba(255,255,255,0.35)',
    fontSize: 10,
  },
  answersSummary: {
    marginTop: 12,
    gap: 6,
  },
  answerText: {
    color: 'rgba(255,255,255,0.5)',
    fontSize: 11.5,
    lineHeight: 16,
  },
  impactContainer: {
    marginTop: 14,
    paddingTop: 10,
    borderTopWidth: 1,
    borderTopColor: 'rgba(255,255,255,0.06)',
  },
  impactTitle: {
    color: 'rgba(255,255,255,0.35)',
    fontSize: 10,
    fontWeight: '600',
    marginBottom: 6,
  },
  impactRow: {
    flexDirection: 'row',
    flexWrap: 'wrap',
    gap: 10,
  },
  impactLabel: {
    fontSize: 10.5,
    fontWeight: '600',
  },
  modalBg: {
    flex: 1,
    backgroundColor: 'rgba(0,0,0,0.65)',
    justifyContent: 'center',
    alignItems: 'center',
  },
  modalWrapper: {
    width: '90%',
    maxWidth: 400,
  },
  modalContent: {
    borderRadius: 24,
    padding: 22,
    borderWidth: 1,
    borderColor: 'rgba(255,255,255,0.08)',
    backgroundColor: 'rgba(10,10,20,0.45)',
    overflow: 'hidden',
  },
  modalHeader: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: 8,
    marginBottom: 10,
  },
  modalTitle: {
    color: '#fff',
    fontSize: 15,
    fontWeight: '700',
    textTransform: 'uppercase',
    letterSpacing: 0.5,
  },
  modalSubtitle: {
    color: 'rgba(255,255,255,0.45)',
    fontSize: 11.5,
    lineHeight: 16,
    marginBottom: 16,
  },
  textArea: {
    backgroundColor: 'rgba(0,0,0,0.25)',
    borderRadius: 14,
    borderWidth: 1,
    borderColor: 'rgba(255,255,255,0.06)',
    padding: 14,
    color: '#fff',
    fontSize: 13,
    lineHeight: 18,
    textAlignVertical: 'top',
    height: 120,
  },
  fieldLabel: {
    color: 'rgba(255,255,255,0.7)',
    fontSize: 11,
    fontWeight: '600',
    marginBottom: 4,
    textTransform: 'uppercase',
    letterSpacing: 0.3,
  },
  fieldInput: {
    backgroundColor: 'rgba(0,0,0,0.25)',
    borderRadius: 12,
    borderWidth: 1,
    borderColor: 'rgba(255,255,255,0.06)',
    paddingHorizontal: 12,
    height: 38,
    color: '#fff',
    fontSize: 12,
  },
  cancelBtn: {
    flex: 1,
